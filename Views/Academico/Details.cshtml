@model Academico_Dependencia.Models.Aluno
@{
    ViewData["Title"] = "Detalhes";
}

<h1>Detalhes</h1>
<h4>Aluno</h4>
<hr />
<dl class="row">
    <dt class="col-sm-2">Nome</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Nome)</dd>
    <dt class="col-sm-2">E-mail</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Email)</dd>
    <dt class="col-sm-2">Telefone</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Telefone)</dd>
    <dt class="col-sm-2">Endereco</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Endereco)</dd>
    <dt class="col-sm-2">Complemento</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Complemento)</dd>
    <dt class="col-sm-2">Bairro</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Bairro)</dd>
    <dt class="col-sm-2">Município</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Municipio)</dd>
    <dt class="col-sm-2">UF</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Uf)</dd>
    <dt class="col-sm-2">CEP</dt>
    <dd class="col-sm-10">@Html.DisplayFor(model => model.Cep)</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.AlunoID">Editar</a> |
<a asp-action="Index">Retornar para a lista de alunos</a>